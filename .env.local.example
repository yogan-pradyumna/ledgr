# Copy this file to .env.local and fill in your values

# Currency symbol displayed in the UI (default: $)
# Examples: $ € £ ¥ ₹ ₩
#VITE_CURRENCY_SYMBOL=$

# Google OAuth 2.0 Client ID
# Create at: https://console.cloud.google.com → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized JavaScript origins: http://localhost:5173
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Spreadsheet ID
# Create a new Google Sheet, then copy the ID from the URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
VITE_SPREADSHEET_ID=your-google-spreadsheet-id

# ---------------------------------------------------------------------------
# LLM for parsing bank statements (server-side — never exposed to browser)
# ---------------------------------------------------------------------------

# Option A: Anthropic Claude (default)
# Get a key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key

# Option B: Any OpenAI-compatible provider (OpenAI, Groq, Ollama, etc.)
# Set all three to switch away from Anthropic. ANTHROPIC_API_KEY is ignored when these are set.
#
# Examples:
#   OpenAI:  LLM_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
#   Groq:    LLM_BASE_URL=https://api.groq.com/openai/v1  LLM_MODEL=llama-3.1-8b-instant
#   Ollama:  LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=llama3.2  (no key needed)
#
#LLM_BASE_URL=https://api.groq.com/openai/v1
#LLM_API_KEY=gsk_your-groq-api-key
#LLM_MODEL=llama-3.1-8b-instant

# ---------------------------------------------------------------------------
# Encryption key (optional but recommended)
# ---------------------------------------------------------------------------
# Encrypts all data in Google Sheets using AES-256-GCM. Without this, anyone
# with access to your spreadsheet URL can read your expense data in plaintext.
#
# This is the only VITE_ key that intentionally runs in the browser —
# encryption and decryption happen client-side before data reaches Google Sheets.
# The key never leaves your machine.
#
# Generate a key once:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Keep this key safe — losing it makes your existing sheet data unrecoverable.
#VITE_ENCRYPTION_KEY=your-base64-encoded-32-byte-key

# Plaid API credentials (only needed for bank sync)
# Sign up at: https://dashboard.plaid.com
# PLAID_ENV: sandbox | development | production
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret-key
PLAID_ENV=sandbox
